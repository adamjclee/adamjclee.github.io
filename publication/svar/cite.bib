@article{HLM21,
  title={Robust Inference in Structural VAR models Identified by non-Gaussianity},
  author={Lukas Hoesch and Adam Lee and Geert Mesters},
  year={2021},
  journal = {Working paper},
  abstract = {Existing methods that exploit non-Gaussian distributions to identify structural im-
pulse responses and conduct inference in SVAR models are not robust to small
deviations from Gaussianity. This leads to coverage distortions for the impulse re-
sponses. We propose a robust and efficient semi-parametric approach to conduct
hypothesis tests and compute confidence bands in the SVAR model. The method
exploits non-Gaussianity when it is present, but yields correct coverage regardless
of the distance to the Gaussian distribution. We evaluate the method in a simula-
tion study and revisit several empirical studies to highlight the limitations of using
non-Gaussianity for identification.} 
}
